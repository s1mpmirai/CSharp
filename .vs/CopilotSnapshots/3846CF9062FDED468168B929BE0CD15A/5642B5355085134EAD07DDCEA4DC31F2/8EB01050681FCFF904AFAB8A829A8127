<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FoodStreetAudioGuide.LoadingPage"
             NavigationPage.HasNavigationBar="False"
             BackgroundColor="#0B0B0F">

    <VerticalStackLayout Padding="24" Spacing="18" VerticalOptions="Center">
        <Border WidthRequest="100" HeightRequest="100" HorizontalOptions="Center" BackgroundColor="#F09A31" Stroke="#6C5CE7" StrokeThickness="3">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="50" />
            </Border.StrokeShape>
            <Label Text="SF" HorizontalOptions="Center" VerticalOptions="Center" FontSize="34" FontAttributes="Bold" TextColor="White" />
        </Border>

        <Label Text="StreetFeast" HorizontalOptions="Center" FontSize="48" FontAttributes="Bold" TextColor="White" />
        <Label Text="AUDIO GUIDE TO STREET FOOD" HorizontalOptions="Center" FontSize="20" FontAttributes="Bold" TextColor="#F09A31" />

        <Border Padding="16" BackgroundColor="#332F2F2F" Stroke="#606060" StrokeThickness="1">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="16" />
            </Border.StrokeShape>

            <VerticalStackLayout Spacing="10">
                <Label Text="PREPARING YOUR TOUR" FontSize="12" FontAttributes="Bold" TextColor="#AAB1BB" />
                <Grid ColumnDefinitions="*,Auto">
                    <Label x:Name="LoadingTextLabel" Text="Loading delicious experiences..." TextColor="White" FontSize="18" />
                    <Label x:Name="ProgressTextLabel" Grid.Column="1" Text="0%" TextColor="#F09A31" FontSize="20" FontAttributes="Bold" />
                </Grid>
                <ProgressBar x:Name="LoadingProgressBar" Progress="0" ProgressColor="#F09A31" BackgroundColor="#595959" HeightRequest="8" />
            </VerticalStackLayout>
        </Border>

        <Label x:Name="StatusLabel" HorizontalOptions="Center" Text="• Connecting to local vendors..." TextColor="#ACB2BC" FontSize="16" />
    </VerticalStackLayout>
</ContentPage>
