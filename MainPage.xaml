<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:maps="http://schemas.microsoft.com/dotnet/2021/maui/maps"
             x:Class="FoodStreetAudioGuide.MainPage"
             Title="Phố Ẩm Thực">

    <Grid RowDefinitions="5*, 5*">

        <maps:Map x:Name="map" Grid.Row="0" Margin="10" IsShowingUser="True">
        </maps:Map>

        <VerticalStackLayout Grid.Row="1" Margin="10,0,10,10">
            <Label Text="Gian hàng quanh bạn" FontSize="18" FontAttributes="Bold" Margin="0,0,0,10" />

            <CollectionView>
                <CollectionView.ItemsSource>
                    <x:Array Type="{x:Type x:String}">
                        <x:String>1. Bánh Mì Huỳnh Hoa - Cách 50m 🔊</x:String>
                        <x:String>2. Quán Ốc Nhớ - Cách 120m</x:String>
                        <x:String>3. Chè Thái Ý Phương - Cách 200m</x:String>
                        <x:String>4. Cơm Tấm Ba Ghiền - Cách 350m</x:String>
                    </x:Array>
                </CollectionView.ItemsSource>
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="0,0,0,10" Padding="15" BackgroundColor="#F8F9FA" StrokeThickness="1" Stroke="#DEE2E6">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="10"/>
                            </Border.StrokeShape>
                            <Label Text="{Binding .}" FontSize="16" TextColor="#333"/>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </VerticalStackLayout>

    </Grid>
</ContentPage>